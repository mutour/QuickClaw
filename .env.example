# OpenClaw Docker Sandbox 部署配置文件模板
# 请将此文件复制为 .env 并根据实际情况修改
# 是否启用沙箱模式 (1 为启用，0 为禁用)
OPENCLAW_SANDBOX=1
# OpenClaw 版本 (latest, 2026.3.11 等)
OPENCLAW_VERSION=latest
# 在 Linux 上通常可以通过 `getent group docker | cut -d: -f3` 获取
DOCKER_GID=999
# OpenClaw 配置目录 (存放插件、日志等)
OPENCLAW_CONFIG_DIR=~/.openclaw
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace
# Gateway 服务端口
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
# 服务监听 IP (127.0.0.1 为仅本机访问，0.0.0.0 为允许局域网访问)
OPENCLAW_LISTEN_IP=127.0.0.1
# Gateway 访问令牌 (建议使用随机长字符串)
OPENCLAW_GATEWAY_TOKEN=your_random_gateway_token_here
# --- AI 模型 API 密钥 (百炼) ---
BAILIAN_API_KEY=your_bailian_api_key_here
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL_NAME=qwen-max

# --- 社交平台 (飞书) ---
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxx
FEISHU_BOT_NAME=OpenClawBot

# 其他插件配置
CLAUDE_AI_SESSION_KEY=
